{
  "name": "GBA Butano Dev",
  "initializeCommand": "bash scripts/start_mgba_bridge.sh",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--add-host=gateway.docker.internal:host-gateway"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/source,type=bind,consistency=cached",
  "workspaceFolder": "/source",
  "containerEnv": {
    "LIBBUTANOABS": "/butano_src/butano",
    "PROJECT_NAME": "${localWorkspaceFolderBasename}",
    "MGBA_BRIDGE_PORT": "17777"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "C_Cpp.default.compilerPath": "/opt/devkitpro/devkitARM/bin/arm-none-eabi-g++",
        "C_Cpp.default.intelliSenseMode": "linux-gcc-arm",
        "C_Cpp.default.cppStandard": "c++17",
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/source/include",
          "${workspaceFolder}/source/src",
          "${env:LIBBUTANOABS}/include",
          "${env:LIBBUTANOABS}/hw/include"
        ]
      }
    }
  }
}
