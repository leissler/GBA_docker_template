{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ROM (debug)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_build.sh debug"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\vscode_build.ps1",
          "-Mode",
          "debug"
        ]
      },
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build ROM (release)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_build.sh release"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\vscode_build.ps1",
          "-Mode",
          "release"
        ]
      },
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean Outputs",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_clean.sh outputs"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\vscode_clean.ps1",
          "-Mode",
          "outputs"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Everything (including Docker stamps)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_clean.sh all"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\vscode_clean.ps1",
          "-Mode",
          "all"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "Launch host emulator (bridge)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/launch_mgba_via_bridge.sh"
      ],
      "windows": {
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\launch_mgba_via_bridge.ps1"
        ]
      },
      "problemMatcher": [],
      "hide": true
    },
    {
      "label": "Prepare Debug Session (build + launch host emulator)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build ROM (debug)",
        "Launch host emulator (bridge)"
      ],
      "problemMatcher": [],
      "hide": true
    }
  ]
}
