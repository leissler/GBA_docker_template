{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ROM (debug)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/build_and_copy_rom.sh debug"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build ROM (release)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/build_and_copy_rom.sh release"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build ROM (host via Docker, release)",
      "type": "process",
      "command": "make",
      "args": [
        "AUTO_CLEAN_MAKE=0",
        "compile-butano",
        "CMD=make -j4 BUILD=build_host_release"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build ROM (host via Docker, debug)",
      "type": "process",
      "command": "make",
      "args": [
        "AUTO_CLEAN_MAKE=0",
        "compile-butano",
        "CMD=make -j4 BUILD=build_host_debug USERFLAGS='-Og -g3' USERCXXFLAGS='-Og -g3'"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean All Outputs (devcontainer/local)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/clean_all_outputs.sh local"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean All Outputs (host via Docker)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/clean_all_outputs.sh host-docker"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean Docker Stamps",
      "type": "process",
      "command": "make",
      "args": [
        "clean-docker-stamps"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean Everything (host via Docker + stamps)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Clean All Outputs (host via Docker)",
        "Clean Docker Stamps"
      ],
      "problemMatcher": []
    },
    {
      "label": "Launch mGBA on host (bridge)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/launch_mgba_via_bridge.sh"
      ],
      "problemMatcher": []
    },
    {
      "label": "Prepare Debug Session (build + launch host mGBA)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build ROM (debug)",
        "Launch mGBA on host (bridge)"
      ],
      "problemMatcher": []
    }
  ]
}
