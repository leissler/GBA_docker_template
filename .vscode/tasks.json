{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build ROM (debug)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_build.sh debug"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build ROM (release)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_build.sh release"
      ],
      "group": {
        "kind": "build"
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean Outputs",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_clean.sh outputs"
      ],
      "problemMatcher": []
    },
    {
      "label": "Clean Everything (including Docker stamps)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/vscode_clean.sh all"
      ],
      "problemMatcher": []
    },
    {
      "label": "Launch host emulator (bridge)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "bash scripts/launch_mgba_via_bridge.sh"
      ],
      "problemMatcher": [],
      "hide": true
    },
    {
      "label": "Prepare Debug Session (build + launch host emulator)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build ROM (debug)",
        "Launch host emulator (bridge)"
      ],
      "problemMatcher": [],
      "hide": true
    }
  ]
}
