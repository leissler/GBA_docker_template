{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to mGBA GDB stub (host:2345)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/source/source.elf",
      "cwd": "${workspaceFolder}/source",
      "MIMode": "gdb",
      "miDebuggerPath": "/opt/devkitpro/devkitARM/bin/arm-none-eabi-gdb",
      "miDebuggerServerAddress": "host.docker.internal:2345",
      "targetArchitecture": "arm",
      "stopAtEntry": true,
      "externalConsole": false,
      "preLaunchTask": "Build ROM (debug)",
      "setupCommands": [
        {
          "description": "Enable GDB pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
