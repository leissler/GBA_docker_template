# Optional host emulator bridge configuration.
# Copy to .emulator-bridge.env and adjust for your machine.

# Bridge settings
# GBA_BRIDGE_PORT=17777
# GBA_BRIDGE_BIND=0.0.0.0

# Default emulator launched by the bridge:
# Supported: mgba (default), visualboyadvance-m
GBA_EMULATOR=mgba

# Optional explicit emulator binary.
# If omitted, auto-discovery is used.

# macOS mGBA:
# GBA_EMULATOR_BIN=/Applications/mGBA.app/Contents/MacOS/mGBA

# Linux mGBA:
# GBA_EMULATOR_BIN=/usr/bin/mgba

# WSL2 using Windows mGBA install:
# GBA_EMULATOR_BIN=/mnt/c/Program Files/mGBA/mGBA.exe

# Windows native PowerShell/CMD:
# GBA_EMULATOR_BIN=C:\\Program Files\\mGBA\\mGBA.exe

# VisualBoyAdvance-M examples (run-only, no GDB debug attach):
# GBA_EMULATOR=visualboyadvance-m
# GBA_EMULATOR_BIN=/usr/bin/visualboyadvance-m
